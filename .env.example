# Токен Telegram-бота от @BotFather
TELEGRAM_TOKEN=8961175683:AAEC4PDS-5fjJAMY0GysnxqjPB72pQzez3Q

# Telegram ID администраторов через запятую — видят ВСЕ ошибки в /errors.
# Свой ID можно узнать у @userinfobot. Пример: ADMIN_IDS=123456789,987654321
ADMIN_IDS=968500846

# ─── Контроль нагрузки на VK (необязательное) ──────────────────────────────
# Сколько публикаций одного пользователя уходит в VK одновременно.
VK_PUBLISH_CONCURRENCY=1
# Сколько всего попыток публикации при временных ошибках VK/сети.
VK_PUBLISH_RETRIES=3
# Базовая задержка между повторами, сек (растёт экспоненциально: 3, 6, 12…).
VK_RETRY_BASE_DELAY=3
# Случайный сдвиг времени публикации вперёд, сек (0 — выключить джиттер).
PUBLISH_JITTER_SECONDS=300

# ─── Планировщик автопубликации ────────────────────────────────────────────
# Во сколько (МСК) раскладывать план на день по всем правилам. Перед раскладкой
# бот до-парсивает все источники-аккаунты (раз в сутки).
DAILY_PLAN_HOUR=0
DAILY_PLAN_MINUTE=5

# Сколько последних видео проверять за один прогон парсера (источник-аккаунт).
PARSE_LIMIT=200

# ─── Хранение логов ошибок ─────────────────────────────────────────────────
ERROR_RETENTION_DAYS=5
ERROR_CLEANUP_INTERVAL_DAYS=5
